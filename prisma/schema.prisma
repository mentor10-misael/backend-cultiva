generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"  
}

model Agricultor {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  eventos   Evento[]
  centroCustos CentroCusto[] 
}

model Evento {
  id        String @id @default (uuid())
  titulo    String
  data      DateTime
  concluido Boolean @default(false)
  tipo      String
  
  agricultorId String
  agricultor Agricultor @relation(fields: [agricultorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agricultorId])

}

model CentroCusto {
  id            String     @id @default(uuid())
  nome          String
  descricao     String?
  ativo         Boolean    @default(true)

  agricultorId  String
  agricultor    Agricultor @relation(fields: [agricultorId], references: [id])

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  @@index([agricultorId])
  @@unique([nome, agricultorId])
}

