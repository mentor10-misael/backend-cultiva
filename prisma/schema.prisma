generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Agricultor {
  id          String        @id @default(uuid())
  nome        String
  email       String        @unique
  ativo       Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  CentroCusto CentroCusto[]

  movimentacoes Movimentacao[]
}

model CentroCusto {
  id           String     @id @default(uuid())
  nome         String
  descricao    String?
  ativo        Boolean    @default(true)
  agricultorId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  deletedAt    DateTime?
  Agricultor   Agricultor @relation(fields: [agricultorId], references: [id])

  movimentacoes Movimentacao[]

  @@unique([nome, agricultorId])
  @@index([agricultorId])
}

model Movimentacao {
  id               String       @id @default(uuid())
  syncId           String       @unique 
  tipo             TipoMovimento
  valor            Decimal      @db.Decimal(10, 2)
  descricao        String
  dataMovimento    DateTime
  formaPagamento   String       
  entidade         String?      
  
  centroCustoId    String
  CentroCusto      CentroCusto  @relation(fields: [centroCustoId], references: [id])
  
  agricultorId     String
  Agricultor       Agricultor   @relation(fields: [agricultorId], references: [id])
  
  criadoEm         DateTime     @default(now())

  @@map("movimentacoes")
}

enum TipoMovimento {
  ENTRADA
  SAIDA
}